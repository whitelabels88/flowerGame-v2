{
  "compilerOptions": {
    "target":           "ES2020",
    "lib":              ["ES2020", "DOM", "DOM.Iterable"],
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "jsx":              "react-jsx",
    "strict":           true,
    "noImplicitAny":    false,
    "noEmit":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "resolveJsonModule": true
  },
  "include": ["src"]
}
